  postagens_postagens_id_bandaTobanda               postagens[]              @relation("postagens_id_bandaTobanda")
  recomendacoes_musicas                             recomendacoes_musicas[]
  redes_sociais                                     redes_sociais[]
  takes                                             takes[]
  videos                                            videos[]
  videosvod                                         videosvod[]
  visitas_banda                                     visitas_banda[]
  visualizacoes_takes                               visualizacoes_takes[]
}

model banda_genero {
  id_banda    Int
  id_genero   Int
  created_at  DateTime?   @default(now()) @db.Timestamp(6)
  banda       banda       @relation(fields: [id_banda], references: [id_banda], onDelete: NoAction, onUpdate: NoAction)
  genero_rock genero_rock @relation(fields: [id_genero], references: [id_genero], onDelete: NoAction, onUpdate: NoAction)

  @@id([id_banda, id_genero])
}

