generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String        @db.VarChar(255)
  slug            String        @unique @db.VarChar(255)
  excerpt         String?
  content         String
  coverImage      String?       @map("cover_image") @db.VarChar(500)
  imageCredit     String?       @map("image_credit") @db.VarChar(255)
  imageCreditUrl  String?       @map("image_credit_url") @db.VarChar(500)
  status          post_status?  @default(draft)
  featured        Boolean?      @default(false)
  publishedAt     DateTime?     @map("published_at") @db.Timestamp(6)
  scheduledAt     DateTime?     @map("scheduled_at") @db.Timestamp(6)
  views           Int?          @default(0)
  metaTitle       String?       @map("meta_title") @db.VarChar(70)
  metaDescription String?       @map("meta_description") @db.VarChar(170)
  focusKeyword    String?       @map("focus_keyword") @db.VarChar(100)
  sourceUrl       String?       @map("source_url") @db.VarChar(500)
  sourceName      String?       @map("source_name") @db.VarChar(100)
  createdAt       DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  categoryId      String?       @map("category_id") @db.Uuid
  authorId        String        @map("author_id") @db.Uuid
  tags            BlogPostTag[]
  author          BlogAuthor    @relation(fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  category        BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([authorId], map: "idx_blog_posts_author_id")
  @@index([categoryId], map: "idx_blog_posts_category_id")
  @@index([publishedAt], map: "idx_blog_posts_published_at")
  @@index([slug], map: "idx_blog_posts_slug")
  @@index([status], map: "idx_blog_posts_status")
  @@map("blog_posts")
}

model BlogCategory {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  description String?
  color       String?    @default("#914100") @db.VarChar(7)
  createdAt   DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  posts       BlogPost[]

  @@index([slug], map: "idx_blog_categories_slug")
  @@map("blog_categories")
}

model BlogAuthor {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String     @db.VarChar(100)
  slug      String     @unique @db.VarChar(100)
  bio       String?
  avatar    String?    @db.VarChar(500)
  email     String     @unique @db.VarChar(255)
  password  String?    @db.VarChar(255)
  isAi      Boolean?   @default(false) @map("is_ai")
  isAdmin   Boolean?   @default(false) @map("is_admin")
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  posts     BlogPost[]

  @@index([email], map: "idx_blog_authors_email")
  @@index([slug], map: "idx_blog_authors_slug")
  @@map("blog_authors")
}

model BlogTag {
  id    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String        @db.VarChar(50)
  slug  String        @unique @db.VarChar(50)
  posts BlogPostTag[]

  @@index([slug], map: "idx_blog_tags_slug")
  @@map("blog_tags")
}

model BlogPostTag {
  postId String   @map("post_id") @db.Uuid
  tagId  String   @map("tag_id") @db.Uuid
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model BlogSettings {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String    @unique @db.VarChar(100)
  value     String
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("blog_settings")
}

model admin_users {
  id_admin   Int       @id @default(autoincrement())
  email      String    @unique @db.VarChar(255)
  senha      String    @db.VarChar(255)
  nome       String    @db.VarChar(100)
  ativo      Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  last_login DateTime? @db.Timestamp(6)
}

model ajuda {
  id             Int             @id @default(autoincrement())
  id_usuario     Int?
  id_banda       Int?
  mensagem       String
  data_envio     DateTime?       @default(now()) @db.Timestamp(6)
  nome           String          @default("Visitante") @db.VarChar(100)
  email          String?         @db.VarChar(150)
  telefone       String?         @db.VarChar(20)
  tela           String?         @db.VarChar(255)
  id_empresa     Int?
  empresa        empresa?        @relation(fields: [id_empresa], references: [id_empresa], onUpdate: NoAction, map: "fk_ajuda_empresa")
  banda          banda?          @relation(fields: [id_banda], references: [id_banda], onUpdate: NoAction, map: "fk_banda")
  tabela_usuario tabela_usuario? @relation(fields: [id_usuario], references: [id_usuario], onUpdate: NoAction, map: "fk_usuario")

  @@index([id_empresa], map: "idx_ajuda_id_empresa")
}

model albuns {
  id_album       Int              @id @default(autoincrement())
  id_banda       Int?
  nome_album     String           @db.VarChar(255)
  ano_lancamento Int?
  url_capa_album String?          @db.VarChar(2048)
  created_at     DateTime?        @db.Timestamp(6)
  deleted_at     DateTime?        @db.Timestamp(6)
  banda          banda?           @relation(fields: [id_banda], references: [id_banda], onDelete: NoAction, onUpdate: NoAction)
  albuns_estante albuns_estante[]
  musicas        musicas[]
  postagens      postagens[]
}

model albuns_estante {
  id              Int            @id @default(autoincrement())
  id_usuario      Int
  id_album        Int
  data_adicionado DateTime?      @default(now()) @db.Timestamptz(6)
  albuns          albuns         @relation(fields: [id_album], references: [id_album], onDelete: NoAction, onUpdate: NoAction)
  tabela_usuario  tabela_usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model albuns_foto {
  id_album_foto     Int       @id @default(autoincrement())
  nome              String    @db.VarChar(100)
  descricao         String?
  id_proprietario   Int
  tipo_proprietario String    @db.VarChar(10)
  data_criacao      DateTime? @default(now()) @db.Timestamp(6)
  deleted_at        DateTime? @db.Timestamp(6)
  foto              foto[]
}

model amigos {
  id_amigo         Int       @id @default(autoincrement())
  id_usu_solicita  Int
  id_usu_recebe    Int
  data_amizade     DateTime? @default(now()) @db.Timestamp(6)
  status           String    @default("aguardando") @db.VarChar(20)
  data_confirmacao DateTime? @db.Timestamp(6)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model analytics_conversions {
  conversion_id      Int                 @id @default(autoincrement())
  session_id         String?             @db.Uuid
  auth_id            Int
  conversion_type    String              @db.VarChar(20)
  city               String?             @db.VarChar(100)
  state              String?             @db.VarChar(100)
  country            String?             @db.VarChar(50)
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  auth               auth                @relation(fields: [auth_id], references: [auth_id], onDelete: Cascade, onUpdate: NoAction)
  analytics_sessions analytics_sessions? @relation(fields: [session_id], references: [session_id], onUpdate: NoAction)

  @@index([auth_id], map: "idx_conversions_auth_id")
  @@index([created_at], map: "idx_conversions_created_at")
  @@index([session_id], map: "idx_conversions_session_id")
  @@index([state], map: "idx_conversions_state")
  @@index([conversion_type], map: "idx_conversions_type")
}

